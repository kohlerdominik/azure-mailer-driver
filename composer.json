{
    "name": "hafael/azure-mailer-driver",
    "description": "Supercharge your Laravel or Symfony app with Microsoft Azure Communication Services (ACS)! Effortlessly add email, chat, voice, video, and telephony-over-IP for next-level communication. 🚀",
    "homepage": "https://github.com/hafael/azure-mailer-driver",
    "type": "library",
    "license": "MIT",
    "keywords": ["azure", "php", "api", "client", "sdk", "ecs", "acs", "azure communication services", "microsoft", "email", "driver", "swift", "mailer", "laravel", "symfony"],
    "require": {
        "php": ">=8.2",
        "illuminate/mail": "^12.0|^13.0",
        "symfony/azure-mailer": "^7.2|^8.0"
    },
    "require-dev": {
        "illuminate/config": "^12.0|^13.0",
        "illuminate/container": "^12.0|^13.0",
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^7.2|^8.0",
        "laravel/pint": "^1.29"
    },
    "authors": [
        {
            "name": "Rafael Villa Verde",
            "email": "villa655321verde@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Hafael\\Mailer\\Azure\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hafael\\Mailer\\Azure\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "symfony/http-client": "Required to enable support for the Symfony API mail transports (^7.2 || ^8.0)."
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "pint": "./vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hafael\\Mailer\\Azure\\AzureMailerServiceProvider"
            ]
        }
    }
}
